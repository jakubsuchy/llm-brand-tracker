# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/brand_tracker

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Application Configuration
NODE_ENV=development

# Analysis Settings (optional)
PROMPTS_PER_TOPIC=20
ANALYSIS_FREQUENCY=daily

# Browser actor — two modes:
# 1. Local: start with `docker compose --profile browser up` (no token needed)
# 2. Cloud: set APIFY_TOKEN to use Apify Cloud (no local container needed)
APIFY_TOKEN=
BROWSER_ACTOR_URL=http://browser-actor:8888

# ChatGPT credentials (optional — ChatGPT works in anonymous mode without these)
CHATGPT_EMAIL=
CHATGPT_PASSWORD=
CHATGPT_TOTP_SECRET=

# Authentication
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
